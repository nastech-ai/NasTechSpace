{
  "id": "continue_after_browser_skill_load_uses_browser_api",
  "description": "after loading the browser skill for an open request, the agent should continue with a browser-api action instead of stopping",
  "history": "../histories/continue_after_browser_skill_load_uses_browser_api.json",
  "expect": {
    "response_type": "thrust",
    "require_staging_line": true,
    "require_separator_line": true,
    "require_single_separator": true,
    "require_code_after_separator": true,
    "require_valid_javascript": true,
    "must_contain": [
      "_____javascript",
      "google.com"
    ],
    "must_match_any": [
      {
        "pattern": "space\\.browser\\.(?:open|create)\\(\"https://(?:www\\.)?google\\.com/?\"\\)",
        "flags": "u"
      }
    ],
    "must_not_match": [
      {
        "pattern": "space\\.skills\\.load\\(\"browser-control\"\\)",
        "flags": "u"
      },
      {
        "pattern": "location\\.(?:href|assign|replace)\\s*=",
        "flags": "u"
      },
      {
        "pattern": "location\\.(?:assign|replace)\\(",
        "flags": "u"
      }
    ],
    "must_not_contain": [
      "Done."
    ]
  }
}
