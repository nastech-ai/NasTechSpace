{
  "id": "page_title_requires_execution",
  "description": "current page questions should trigger a live browser read, not a conversational guess",
  "history": "../histories/page_title_requires_execution.json",
  "expect": {
    "response_type": "thrust",
    "require_staging_line": true,
    "require_separator_line": true,
    "require_single_separator": true,
    "require_code_after_separator": true,
    "require_valid_javascript": true,
    "must_contain": [
      "_____javascript"
    ],
    "must_match": [
      {
        "pattern": "document\\.title|location\\.href|window\\.location\\.href",
        "flags": "u"
      }
    ],
    "must_not_contain": [
      "I can tell you",
      "If you tell me",
      "I need more context"
    ]
  }
}
