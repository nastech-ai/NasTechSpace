{
  "id": "weather_after_place_prerequisite",
  "description": "if a place lookup happens inside a weather task, the agent should continue to weather instead of stopping on place identity",
  "history": "../histories/weather_after_place_prerequisite.json",
  "expect": {
    "response_type": "thrust",
    "require_staging_line": true,
    "require_separator_line": true,
    "require_single_separator": true,
    "require_code_after_separator": true,
    "require_valid_javascript": true,
    "must_contain": [
      "_____javascript"
    ],
    "must_match": [
      {
        "pattern": "(?:open-meteo|wttr\\.in)",
        "flags": "u"
      }
    ],
    "must_not_match": [
      {
        "pattern": "nominatim|reverse\\?format",
        "flags": "iu"
      }
    ],
    "must_not_contain": [
      "Hnojice, okres Olomouc",
      "Central Moravia",
      "Your location is",
      "It’s at 250",
      "It's at 250"
    ]
  }
}
