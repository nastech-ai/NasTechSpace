{
  "id": "continue_after_widget_read",
  "description": "after a widget read that unlocks the next write, the agent should continue with execution",
  "history": "../histories/continue_after_widget_read.json",
  "expect": {
    "response_type": "thrust",
    "require_staging_line": true,
    "require_separator_line": true,
    "require_single_separator": true,
    "require_code_after_separator": true,
    "require_valid_javascript": true,
    "must_contain": [
      "_____javascript",
      "snake-game"
    ],
    "must_match": [
      {
        "pattern": "space\\.current\\.patchWidget\\(\"snake-game\"",
        "flags": "u"
      }
    ],
    "must_not_match": [
      {
        "pattern": "space\\.current\\.(?:widget|updateWidget|writeWidget)\\(",
        "flags": "u"
      }
    ],
    "must_not_contain": [
      "I’ve got the Snake widget source loaded",
      "I've got the Snake widget source loaded",
      "can patch next",
      "loaded and can patch next"
    ]
  }
}
