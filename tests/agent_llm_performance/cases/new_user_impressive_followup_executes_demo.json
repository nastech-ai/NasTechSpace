{
  "id": "new_user_impressive_followup_executes_demo",
  "description": "after a lazy onboarding menu, a follow-up request to do something impressive should execute one concrete demo instead of another menu or clarification",
  "history": "../histories/new_user_impressive_followup_executes_demo.json",
  "expect": {
    "response_type": "thrust",
    "require_staging_line": true,
    "require_separator_line": true,
    "require_single_separator": true,
    "require_code_after_separator": true,
    "require_valid_javascript": true,
    "must_contain": [
      "_____javascript"
    ],
    "must_match_any": [
      {
        "pattern": "renderWidget\\(",
        "flags": "u"
      },
      {
        "pattern": "document\\.title|location\\.href|window\\.location\\.href",
        "flags": "u"
      },
      {
        "pattern": "screenshotDownload\\(|takeScreenshot\\(|html2canvas",
        "flags": "u"
      },
      {
        "pattern": "document\\.createElement|appendChild\\(|animate\\(",
        "flags": "u"
      },
      {
        "pattern": "document\\.documentElement|style\\.transform|rotate\\(180deg\\)",
        "flags": "u"
      }
    ],
    "must_not_match": [
      {
        "pattern": "If you want|say one of|Pick one|I can do one of these|tell me what|show you a few useful things",
        "flags": "iu"
      }
    ]
  }
}
